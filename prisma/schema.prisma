// Schema Prisma — CRM Cuberfit
// Module P0-1 : Contacts & comptes (+ tables de journalisation Vue 360° :
// Interaction et RisqueScoreSnapshot, explicitement demandées dans le
// périmètre P0-1 pour l'historique complet du compte).
//
// Les moteurs de calcul (Score de risque P0-3, tickets/SLA P0-5, campagnes P0-4)
// seront ajoutés aux modules suivants — ce schéma ne pose que les fondations
// et les points d'accroche (relations, journal d'événements) dont ils auront besoin.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

/// Les 3 personas canoniques de la stratégie Customer Success Cuberfit.
enum Segment {
  PASSIONNE
  PARTENAIRE
  ENTREPRISE_QVT
}

/// Niveau d'accompagnement CS — détermine le mode de suivi (automatisé vs dédié).
enum NiveauAccompagnement {
  TECH_TOUCH
  LOW_TOUCH
  HIGH_TOUCH
}

/// Phase du lifecycle client (module P0-2, référencée dès P0-1 pour la vue liste/fiche).
enum PhaseLifecycle {
  ONBOARDING
  ADOPTION
  EXPANSION
  A_RISQUE
  CHURN
}

/// Statut couleur du Score de risque (seuils définis dans le module P0-3).
enum StatutRisqueScore {
  VERT
  ORANGE
  ROUGE
}

enum StatutAbonnement {
  AUCUN
  ACCESS
  PLAY
  ACCESS_PLAY
}

enum TypeActivitePartenaire {
  SALLE
  STUDIO
  COACH_INDEPENDANT
  ESPACE_BIEN_ETRE
}

/// Type d'événement journalisé dans la timeline Vue 360° d'un compte.
enum TypeInteraction {
  ACHAT
  TICKET
  CAMPAGNE
  APPEL_AGENT_VOCAL
  RISQUE_SCORE_CHANGE
  NOTE
}

/// Réconcilié le 2026-07-08 avec l'organisation CX réelle du Vision Book
/// (voir Cuberfit_Access_PRD.docx section 15) : remplace les intitulés
/// génériques "CSM Entreprise/Partenaire" et "Sales/BizDev" par les vrais
/// métiers Cuberfit.
enum RoleUtilisateur {
  ADMIN
  ACTIVATION_MANAGER // Partenaires — parcours complet Découverte→Ambassadeur
  SALES_CORPORATE // Entreprises QVT — avant signature
  ACCOUNT_MANAGER // Entreprises QVT — après signature (renouvellement, upsell)
  CS_OPS_SUPPORT
  LECTURE_SEULE
}

/// Événement qui déclenche le démarrage d'un playbook (module P0-2).
enum TypeDeclencheurPlaybook {
  ENTREE_PHASE // le compte entre dans une PhaseLifecycle donnée
  INACTIVITE // aucune activité depuis seuilJoursInactivite jours ("client silencieux")
  RECLAMATION // usage en baisse + réclamation ("client à risque")
  ALERTE_RISQUE_SCORE // changement de StatutRisqueScore (branché au moteur P0-3)
  MANUEL // déclenché à la main par un utilisateur CRM
}

enum StatutPlaybookExecution {
  EN_COURS
  TERMINEE
  ANNULEE
}

enum StatutEtapePlaybook {
  A_FAIRE
  FAITE
  IGNOREE
}

enum TypeActionEtape {
  RELANCE_AUTO // email/SMS/WhatsApp automatique (connecté N8N en P0-4)
  TACHE_MANUELLE // tâche assignée à un humain (CSM, Support, Sales)
  NOTIFICATION_INTERNE // alerte interne uniquement, pas de contact client
}

enum CanalCommunication {
  EMAIL
  SMS
  WHATSAPP
  APPEL
  AUCUN
}

/// Les 3 "moments de vérité" actés dans la stratégie CS, un par segment.
enum TypeMomentDeVerite {
  PREMIERE_SESSION_REUSSIE // Passionnés
  PREMIERE_RESERVATION // Partenaires
  PREMIER_REPORTING_QVT_POSITIF // Entreprises QVT
}

// ---------------------------------------------------------------------------
// UTILISATEURS INTERNES CRM (rôles — voir section 4 du prompt source)
// ---------------------------------------------------------------------------

model UtilisateurCRM {
  id           String          @id @default(cuid())
  prenom       String
  nom          String
  email        String          @unique
  role         RoleUtilisateur
  actif        Boolean         @default(true)
  dateCreation DateTime        @default(now())

  comptesGeres          Account[]                @relation("CSMAssigne")
  tachesAssignees       EtapeExecution[]         @relation("TacheAssignee")
  ponderationsModifiees PonderationRisqueScore[] @relation("PonderationModifiee")
  ticketsAssignes       Ticket[]                 @relation("TicketAssigne")
  opportunitesGerees    Opportunite[]            @relation("OpportuniteProprietaire")

  @@map("utilisateurs_crm")
}

// ---------------------------------------------------------------------------
// ACCOUNT — entité pivot commune aux 3 segments (façon "Account" Salesforce)
// ---------------------------------------------------------------------------

model Account {
  id                   String               @id @default(cuid())
  segment              Segment
  nom                  String
  niveauAccompagnement NiveauAccompagnement
  phaseLifecycle       PhaseLifecycle       @default(ONBOARDING)

  // Dénormalisé pour affichage rapide (liste comptes, dashboard) ; la valeur
  // de référence reste le dernier RisqueScoreSnapshot. Recalculé par le
  // moteur du module P0-3 à chaque nouveau snapshot.
  risqueScoreActuel Int?
  risqueScoreStatut StatutRisqueScore?

  csmAssigneId String?
  csmAssigne   UtilisateurCRM? @relation("CSMAssigne", fields: [csmAssigneId], references: [id])

  dateCreation    DateTime @default(now())
  dateDerniereMaj DateTime @updatedAt

  contacts              Contact[]
  interactions          Interaction[]
  risqueScoreHistorique RisqueScoreSnapshot[]

  passionneProfile     PassionneProfile?
  partenaireProfile    PartenaireProfile?
  entrepriseQvtProfile EntrepriseQvtProfile?

  // Un Passionné peut avoir plusieurs coachs associés ; un coach (compte
  // Partenaire de type COACH_INDEPENDANT) peut suivre plusieurs Passionnés.
  coachsAssocies CoachAssociation[] @relation("PassionneCoachs")
  clientsSuivis  CoachAssociation[] @relation("CoachPassionnes")

  // Module P0-2 : Onboarding & lifecycle
  playbookExecutions PlaybookExecution[]
  momentsDeVerite    MomentDeVerite[]

  // Module P0-4 : Communication multicanale
  campagneEnvois CampagneEnvoi[]

  // Module P0-5 : Tickets & support
  tickets Ticket[]

  // Module P1-1 : Pipeline & Opportunités
  opportunites Opportunite[]

  // Module P1-3 : NPS & feedback
  reponsesEnquete ReponseEnquete[]

  @@index([segment])
  @@index([phaseLifecycle])
  @@index([risqueScoreStatut])
  @@map("accounts")
}

/// Personne physique rattachée à un compte (interlocuteur RH, gérant de salle,
/// contact secondaire...). Pour les Passionnés, l'identité vit directement
/// sur PassionneProfile puisque le compte EST la personne.
model Contact {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  prenom              String
  nom                 String
  email               String?
  telephone           String?
  role                String? // ex: "Interlocuteur RH", "Gérant de salle"
  estContactPrincipal Boolean @default(false)

  dateCreation DateTime @default(now())

  @@index([accountId])
  @@map("contacts")
}

/// Association Passionné <-> Coach (compte Partenaire de type COACH_INDEPENDANT).
model CoachAssociation {
  id String @id @default(cuid())

  passionneAccountId String
  passionneAccount   Account @relation("PassionneCoachs", fields: [passionneAccountId], references: [id], onDelete: Cascade)

  coachAccountId String
  coachAccount   Account @relation("CoachPassionnes", fields: [coachAccountId], references: [id], onDelete: Cascade)

  dateDebut DateTime @default(now())
  actif     Boolean  @default(true)

  @@unique([passionneAccountId, coachAccountId])
  @@map("coach_associations")
}

// ---------------------------------------------------------------------------
// FICHES SPÉCIFIQUES PAR SEGMENT (1-1 avec Account)
// ---------------------------------------------------------------------------

/// Fiche Passionné (B2C) — utilisateur final de l'app Access.
model PassionneProfile {
  id        String  @id @default(cuid())
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  email         String    @unique
  telephone     String?
  dateNaissance DateTime?
  ville         String?

  statutAbonnement StatutAbonnement @default(AUCUN)

  // Historique crédits
  creditsAchetes   Int @default(0)
  creditsConsommes Int @default(0)
  creditsDormants  Int @default(0)

  // No-show & annulations (entrent dans le Score de risque, poids 10%)
  nombreNoShow      Int @default(0)
  nombreAnnulations Int @default(0)

  // NPS le plus récent déclaré (échelle -100 à 100 ; à confirmer avec Awa/Fatou)
  npsScore Int?

  dateDerniereActivite DateTime?

  @@map("passionne_profiles")
}

/// Fiche Partenaire (B2B2C) — salle, studio, espace bien-être ou coach indépendant.
model PartenaireProfile {
  id        String  @id @default(cuid())
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  typeActivite TypeActivitePartenaire
  ville        String?
  adresse      String?

  statutProfilCompletudePct Int  @default(0) // 0-100
  tauxRemplissageMoyenPct   Int? // 0-100
  reservationsRecuesTotal   Int  @default(0)

  // Satisfaction déclarée par le partenaire (échelle 0-10 ; à confirmer)
  satisfactionScore Int?

  dateSignature DateTime?

  @@map("partenaire_profiles")
}

/// Fiche Entreprise QVT (B2B) — budget qualité de vie au travail.
model EntrepriseQvtProfile {
  id        String  @id @default(cuid())
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  secteurActivite String?
  tailleEffectif  Int?

  budgetAllouAnnuel    Decimal? @db.Decimal(12, 2)
  budgetConsommeAnnuel Decimal? @db.Decimal(12, 2)

  pctEmployesActives        Int? // 0-100, activés au moins une fois
  pctEmployesActifsMensuels Int? // 0-100, actifs sur le mois en cours

  dateSignature      DateTime?
  dateRenouvellement DateTime?

  @@map("entreprise_qvt_profiles")
}

// ---------------------------------------------------------------------------
// JOURNAL D'ÉVÉNEMENTS — alimente la Vue 360° du compte (spec P0-1)
// ---------------------------------------------------------------------------

/// Historique complet des interactions d'un compte : achats, tickets,
/// campagnes reçues, appels agent vocal. Les modules P0-4/P0-5 écriront ici ;
/// P0-1 ne fait que poser la table pour que la Vue 360° ait une timeline.
model Interaction {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type        TypeInteraction
  titre       String
  description String?
  metadata    Json? // détails spécifiques au type (ex: id ticket, canal, montant)

  dateInteraction DateTime @default(now())
  creePar         String? // nom utilisateur CRM ou "Agent vocal ElevenLabs"

  @@index([accountId, dateInteraction])
  @@map("interactions")
}

/// Snapshot du Score de risque à un instant T, pour tracer "Score de risque dans le
/// temps" en Vue 360°. Le calcul lui-même (pondérations, seuils) est le
/// moteur du module P0-3 — ici on ne stocke que le résultat historisé.
model RisqueScoreSnapshot {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  score          Int // 0-100
  statut         StatutRisqueScore
  detailCriteres Json // décomposition par critère pondéré (P0-3)

  dateCalcul DateTime @default(now())

  @@index([accountId, dateCalcul])
  @@map("risque_score_snapshots")
}

// ---------------------------------------------------------------------------
// MODULE P0-2 — ONBOARDING & LIFECYCLE (playbooks par phase)
//
// Reproduit les 3 phases actées (Onboarding / Adoption / Expansion) et les
// playbooks de gestion de crise du prompt source, sous forme de règles
// explicites if/then : un Playbook se déclenche (TypeDeclencheurPlaybook),
// exécute une suite d'PlaybookEtape datées en J+n, et produit un
// PlaybookExecution/EtapeExecution par compte pour le suivi. Les
// MomentDeVerite sont trackés séparément car ils ne sont pas des étapes à
// accomplir mais des jalons à observer (1ère session réussie, etc.).
// ---------------------------------------------------------------------------

/// Modèle (template) de playbook — configurable sans redéploiement, à l'image
/// des pondérations Score de risque.
model Playbook {
  id          String  @id @default(cuid())
  nom         String
  description String?

  // null = s'applique à tous les segments (ex: crise technique)
  segment Segment?

  // Phase qui déclenche le playbook si typeDeclencheur = ENTREE_PHASE ;
  // null pour les playbooks de crise déclenchés autrement.
  phaseCible PhaseLifecycle?

  typeDeclencheur TypeDeclencheurPlaybook

  // Utilisé uniquement si typeDeclencheur = INACTIVITE ("relance auto si
  // inactivité > X jours").
  seuilJoursInactivite Int?

  actif        Boolean  @default(true)
  dateCreation DateTime @default(now())

  etapes     PlaybookEtape[]
  executions PlaybookExecution[]

  @@index([segment, phaseCible])
  @@map("playbooks")
}

/// Étape ordonnée d'un playbook, avec son délai depuis le déclenchement
/// (ex: "relance J+3", "relance J+7").
model PlaybookEtape {
  id         String   @id @default(cuid())
  playbookId String
  playbook   Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  ordre       Int
  titre       String
  description String?
  delaiJours  Int                @default(0)
  typeAction  TypeActionEtape
  canal       CanalCommunication @default(AUCUN)

  // Renseigné pour les étapes typeAction = RELANCE_AUTO : quel template
  // (module P0-4) cette relance automatique envoie.
  templateId String?
  template   TemplateCommunication? @relation(fields: [templateId], references: [id])

  executions EtapeExecution[]

  @@unique([playbookId, ordre])
  @@map("playbook_etapes")
}

/// Instance d'un Playbook en cours (ou terminé) pour un compte donné.
model PlaybookExecution {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  playbookId String
  playbook   Playbook @relation(fields: [playbookId], references: [id])

  statut            StatutPlaybookExecution @default(EN_COURS)
  dateDeclenchement DateTime                @default(now())
  dateFin           DateTime?

  etapes EtapeExecution[]

  @@index([accountId, statut])
  @@map("playbook_executions")
}

/// Réalisation (ou non) d'une PlaybookEtape pour une exécution donnée.
model EtapeExecution {
  id          String            @id @default(cuid())
  executionId String
  execution   PlaybookExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  etapeId String
  etape   PlaybookEtape @relation(fields: [etapeId], references: [id])

  statut          StatutEtapePlaybook @default(A_FAIRE)
  dateEcheance    DateTime
  dateRealisation DateTime?

  // Renseigné uniquement pour les étapes typeAction = TACHE_MANUELLE.
  assigneAId String?
  assigneA   UtilisateurCRM? @relation("TacheAssignee", fields: [assigneAId], references: [id])

  @@index([executionId, statut])
  @@map("etape_executions")
}

/// Jalon à observer (pas une tâche à cocher) : un par segment, actés dans la
/// stratégie CS comme signal de réussite de l'onboarding.
model MomentDeVerite {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type TypeMomentDeVerite

  // Échéance cible (ex: J+14 depuis la création du compte) pour calibrer les
  // alertes "toujours pas atteint à J+X".
  dateCibleAvant DateTime?
  dateAtteint    DateTime?

  @@unique([accountId, type])
  @@map("moments_de_verite")
}

// ---------------------------------------------------------------------------
// MODULE P0-3 — SCORE DE RISQUE & CHURN
//
// Le score par compte reste calculé et historisé via RisqueScoreSnapshot
// (posé en P0-1, section Vue 360°). Ce que P0-3 ajoute : les pondérations
// par critère et par segment, éditables par un Admin sans redéploiement —
// exigence explicite du prompt source, les poids actuels étant "indicatifs,
// à challenger après la V0". Les seuils (Vert 70-100 / Orange 40-69 /
// Rouge 0-39) restent fixes : seuls les poids sont configurables ici.
// ---------------------------------------------------------------------------

/// Un critère pondéré du score, spécifique à un segment (les 3 segments
/// n'utilisent pas les mêmes critères).
enum CritereRisqueScore {
  // Passionnés
  FREQUENCE_UTILISATION // 35%
  DERNIERE_ACTIVITE // 25%
  NPS_SATISFACTION // 20%
  NO_SHOW_ANNULATIONS // 10%

  // Partenaires
  RESERVATIONS_VIA_CUBERFIT // 35%
  TAUX_REMPLISSAGE_MOYEN // 25%
  SATISFACTION_PARTENAIRE // 20%
  ACTIVITE_COMPTE // 10%

  // Commun Passionnés & Partenaires
  TICKETS_OUVERTS // 10%

  // Entreprises QVT
  PCT_EMPLOYES_ACTIFS_MENSUELS // 30%
  PCT_EMPLOYES_ACTIVES // 20%
  TENDANCE_USAGE // 20%
  BUDGET_CONSOMME // 15%
  RENOUVELLEMENT_PROBABLE // 15%
}

/// Pondération éditable d'un critère pour un segment. La somme des poidsPct
/// pour un même segment doit valoir 100 — vérifié côté application (pas de
/// contrainte SQL, pour permettre un état transitoire pendant l'édition).
model PonderationRisqueScore {
  id       String             @id @default(cuid())
  segment  Segment
  critere  CritereRisqueScore
  poidsPct Int // 0-100

  dateDerniereMaj DateTime        @updatedAt
  modifieParId    String?
  modifiePar      UtilisateurCRM? @relation("PonderationModifiee", fields: [modifieParId], references: [id])

  @@unique([segment, critere])
  @@map("ponderations_risque_score")
}

// ---------------------------------------------------------------------------
// MODULE P0-4 — COMMUNICATION MULTICANALE
//
// Templates par segment/phase de lifecycle (réutilisés par les playbooks
// P0-2 pour les relances automatiques) + campagnes ponctuelles avec suivi
// d'envoi par canal. La connexion N8N pour l'automatisation d'envoi est un
// point d'intégration documenté (voir Paramètres → Intégrations dans le
// blueprint produit), pas implémentée ici : ce module pose le modèle de
// données que N8N viendra consommer/alimenter.
// ---------------------------------------------------------------------------

enum StatutCampagne {
  BROUILLON
  PLANIFIEE
  ENVOYEE
  TERMINEE
  ANNULEE
}

enum StatutEnvoiCampagne {
  EN_ATTENTE
  ENVOYE
  LIVRE
  LU
  CLIQUE
  ECHEC
}

/// Modèle de message réutilisable, propre à un segment et/ou une phase de
/// lifecycle (onboarding/adoption/expansion/crise). Sert à la fois aux
/// campagnes ponctuelles et aux relances automatiques des playbooks P0-2.
model TemplateCommunication {
  id      String             @id @default(cuid())
  nom     String
  canal   CanalCommunication
  segment Segment? // null = tous segments
  phase   PhaseLifecycle? // null = hors lifecycle (ex: crise, ponctuel)

  sujet String? // pertinent pour EMAIL uniquement
  corps String // contenu du message, variables type {{prenom}}

  actif        Boolean  @default(true)
  dateCreation DateTime @default(now())

  campagnes      Campagne[]
  etapesPlaybook PlaybookEtape[]

  @@index([segment, phase])
  @@map("templates_communication")
}

/// Campagne ponctuelle envoyée à un segment (ou à tous), via un template et
/// un canal donnés.
model Campagne {
  id          String  @id @default(cuid())
  nom         String
  description String?

  segmentCible Segment? // null = tous segments
  phaseCible   PhaseLifecycle? // null = pas de ciblage par phase
  canal        CanalCommunication

  templateId String
  template   TemplateCommunication @relation(fields: [templateId], references: [id])

  statut        StatutCampagne @default(BROUILLON)
  datePlanifiee DateTime?
  dateEnvoi     DateTime?
  dateCreation  DateTime       @default(now())

  envois CampagneEnvoi[]

  @@map("campagnes")
}

/// Trace d'envoi d'une campagne à un compte précis — alimente le dashboard
/// "Performance par canal".
model CampagneEnvoi {
  id         String   @id @default(cuid())
  campagneId String
  campagne   Campagne @relation(fields: [campagneId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  statut      StatutEnvoiCampagne @default(EN_ATTENTE)
  dateEnvoi   DateTime?
  dateLecture DateTime?

  @@unique([campagneId, accountId])
  @@map("campagne_envois")
}

// ---------------------------------------------------------------------------
// MODULE P0-5 — TICKETS & SUPPORT (façon "Service Cloud / Cases")
//
// SLA cibles actés : 1ère réponse < 4h ouvrées, résolution standard 24-48h
// (hors incidents majeurs), ≈80% des demandes routine traitées par l'agent
// vocal RVI — les 20% résiduels génèrent automatiquement un ticket
// (origine = AUTO_AGENT_VOCAL). CSAT recueilli à la clôture.
// ---------------------------------------------------------------------------

enum CanalEntreeTicket {
  APP_MOBILE
  WHATSAPP
  EMAIL
  AGENT_VOCAL
  APPEL_TELEPHONIQUE
}

/// Priorités métier Cuberfit, en complément des SLA génériques.
enum PrioriteTicket {
  URGENTE // ex: paiement débité sans crédit, donnée de santé Bloom compromise — hors SLA standard, traitement immédiat
  HAUTE // ex: réservation annulée sans remboursement, litige coach/partenaire — dans le SLA 4h/24-48h
  MOYENNE // ex: question crédits dormants, modification profil — SLA standard
  BASSE // ex: question générale, suggestion produit — self-service en priorité
}

enum StatutTicket {
  OUVERT
  EN_COURS
  EN_ATTENTE_CLIENT
  RESOLU
  FERME
}

/// Distingue les tickets créés manuellement de ceux créés automatiquement
/// par l'agent vocal (escalade des ~20% de demandes non résolues par le RVI).
enum OrigineTicket {
  MANUEL
  AUTO_AGENT_VOCAL
}

model Ticket {
  id     String @id @default(cuid())
  numero Int    @default(autoincrement())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  sujet       String
  description String?
  canalEntree CanalEntreeTicket
  priorite    PrioriteTicket
  statut      StatutTicket      @default(OUVERT)
  origine     OrigineTicket     @default(MANUEL)

  assigneAId String?
  assigneA   UtilisateurCRM? @relation("TicketAssigne", fields: [assigneAId], references: [id])

  dateCreation        DateTime  @default(now())
  datePremiereReponse DateTime?
  dateResolution      DateTime?

  // CSAT recueilli à la clôture du ticket (échelle 1-5).
  csatScore       Int?
  csatCommentaire String?

  @@index([accountId, statut])
  @@index([priorite, statut])
  @@map("tickets")
}

// ---------------------------------------------------------------------------
// MODULE P1-1 — PIPELINE & OPPORTUNITÉS (Partenaires + Entreprises QVT)
//
// Le pipeline Partenaires reprend le vrai parcours de l'Activation Manager
// (Vision Book, section 14 du PRD Access) plutôt qu'un pipeline générique :
// Découverte → Diagnostic → Démonstration → Engagement → Onboarding →
// Suivi actif → Ambassadeur. Le pipeline QVT reste celui déjà cadré dans le
// blueprint : Prospect → RDV DRH → Démo → Proposition → Signature →
// Onboarding → Adoption → Renouvellement.
// Une seule Opportunite peut appartenir à un compte Partenaire OU QVT — les
// Passionnés n'ont pas d'opportunité commerciale. Seul le champ d'étape
// correspondant au segment du compte est renseigné (même logique que les
// profils par segment de P0-1).
// ---------------------------------------------------------------------------

enum EtapePipelinePartenaire {
  DECOUVERTE
  DIAGNOSTIC
  DEMONSTRATION
  ENGAGEMENT
  ONBOARDING
  SUIVI_ACTIF
  AMBASSADEUR
}

enum EtapePipelineQvt {
  PROSPECT
  RDV_DRH
  DEMO
  PROPOSITION
  SIGNATURE
  ONBOARDING
  ADOPTION
  RENOUVELLEMENT
}

enum TypeOpportunite {
  NOUVELLE_AFFAIRE
  UPSELL
  RENOUVELLEMENT
}

enum StatutOpportunite {
  EN_COURS
  GAGNEE
  PERDUE
}

model Opportunite {
  id String @id @default(cuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Dupliqué depuis account.segment pour permettre l'indexation et éviter un
  // join sur chaque vue kanban ; doit toujours correspondre à account.segment.
  segment Segment
  type    TypeOpportunite @default(NOUVELLE_AFFAIRE)

  etapePartenaire EtapePipelinePartenaire? // renseigné si segment = PARTENAIRE
  etapeQvt        EtapePipelineQvt? // renseigné si segment = ENTREPRISE_QVT

  statut StatutOpportunite @default(EN_COURS)

  montantEstimeAnnuel Decimal? @db.Decimal(12, 2)
  probabilitePct      Int? // 0-100

  proprietaireId String?
  proprietaire   UtilisateurCRM? @relation("OpportuniteProprietaire", fields: [proprietaireId], references: [id])

  dateCreation      DateTime  @default(now())
  dateClotureprevue DateTime?
  dateCloture       DateTime?

  @@index([segment, etapePartenaire])
  @@index([segment, etapeQvt])
  @@map("opportunites")
}

// ---------------------------------------------------------------------------
// MODULE P1-2 — ANALYTICS & REPORTING (dashboards KPIs, alertes, cohortes)
//
// Les KPIs de référence par segment (grille section 3 du prompt cadrage) sont
// une liste fermée et connue à l'avance (6 par segment) : leurs métadonnées
// (libellé, unité, cible, sens d'amélioration) sont donc codées en dur côté
// application plutôt que modélisées en base — seul l'historique des valeurs
// mesurées (KpiSnapshot) est une donnée. Les alertes ne sont pas non plus un
// modèle séparé : elles sont dérivées à la volée en comparant le dernier
// KpiSnapshot de chaque KPI à sa cible, sur le même principe que les comptes
// "ROUGE" du Score de risque en P0-3.
// ---------------------------------------------------------------------------

/// Valeur mensuelle mesurée d'un KPI pour un segment. `codeKpi` référence une
/// des clés fixes définies dans src/lib/kpis.ts (ex. "TAUX_ACTIVATION").
model KpiSnapshot {
  id String @id @default(cuid())

  segment Segment
  codeKpi String
  periode DateTime // premier jour du mois mesuré

  valeur Decimal @db.Decimal(6, 2)

  @@unique([segment, codeKpi, periode])
  @@index([segment, codeKpi])
  @@map("kpi_snapshots")
}

/// Rétention d'une cohorte mensuelle (ex. tous les Passionnés inscrits en
/// janvier) observée à M+0, M+1, M+2... — uniquement pertinent pour les
/// segments où l'acquisition se fait individu par individu (Passionnés,
/// Partenaires) ; les Entreprises QVT sont trop peu nombreuses pour une
/// analyse de cohorte et suivent plutôt un renouvellement contractuel.
model CohorteRetention {
  id String @id @default(cuid())

  segment         Segment
  moisCohorte     DateTime // mois d'acquisition de la cohorte
  moisObservation Int // décalage en mois depuis l'acquisition (0, 1, 2...)

  tailleInitiale Int
  pctRetenu      Decimal @db.Decimal(5, 2)

  @@unique([segment, moisCohorte, moisObservation])
  @@map("cohortes_retention")
}

// ---------------------------------------------------------------------------
// MODULE P1-3 — NPS & FEEDBACK (enquêtes, verbatims, boucle produit)
//
// Remplace à terme les champs scalaires isolés PassionneProfile.npsScore et
// PartenaireProfile.satisfactionScore (une seule valeur, sans historique ni
// verbatim) par un historique complet de réponses. Reprend le même schéma
// relationnel que Campagne/CampagneEnvoi (P0-4) : une Enquete est une vague
// envoyée à un segment, une ReponseEnquete est la réponse individuelle d'un
// compte. `statutTraitement` porte la boucle produit : un verbatim NOUVEAU
// doit être lu et qualifié (EN_COURS) puis clos (TRAITE) par le CS.
// ---------------------------------------------------------------------------

enum TypeEnquete {
  NPS_RELATIONNEL // vague périodique de satisfaction globale
  NPS_TRANSACTIONNEL // envoyée après un moment clé (fin d'onboarding, ticket résolu...)
}

enum StatutTraitementVerbatim {
  NOUVEAU
  EN_COURS
  TRAITE
}

model Enquete {
  id String @id @default(cuid())

  nom          String
  type         TypeEnquete
  segmentCible Segment?

  dateEnvoi    DateTime
  dateCreation DateTime @default(now())

  reponses ReponseEnquete[]

  @@map("enquetes")
}

model ReponseEnquete {
  id        String  @id @default(cuid())
  enqueteId String
  enquete   Enquete @relation(fields: [enqueteId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  score            Int // 0-10, échelle NPS standard
  verbatim         String?
  statutTraitement StatutTraitementVerbatim @default(NOUVEAU)

  dateReponse DateTime @default(now())

  @@index([enqueteId])
  @@index([accountId])
  @@index([statutTraitement])
  @@map("reponses_enquete")
}
